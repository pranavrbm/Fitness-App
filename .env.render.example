# Environment variables template for Render deployment
# Copy these values from your MongoDB Atlas and Render services after deployment

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/fitness_app?retryWrites=true&w=majority

# Spring Profiles (set to 'render' for production)
SPRING_PROFILES_ACTIVE=render

# Config Server (Render service URL)
CONFIG_SERVER_URL=https://config-server-xxxxx.onrender.com

# Eureka Server (Render service URL)
EUREKA_SERVER_URL=https://eureka-server-xxxxx.onrender.com/eureka

# Microservices URLs (Render service URLs)
ACTIVITY_SERVICE_URL=https://activity-service-xxxxx.onrender.com
USER_SERVICE_URL=https://user-service-xxxxx.onrender.com
AI_SERVICE_URL=https://ai-service-xxxxx.onrender.com

# Frontend API URL
VITE_API_URL=https://api-gateway-xxxxx.onrender.com
